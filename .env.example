# Database
DATABASE_URL="mysql://user:password@localhost:3306/polarisone"

# Authentication
JWT_SECRET="replace-with-a-32-character-minimum-secret"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_EXPIRES_IN_DAYS="30"
NEXTAUTH_URL="https://app.example.com"
NEXTAUTH_SECRET="replace-with-a-nextauth-secret"

# External APIs
ROBLOX_API_BASE="https://apis.roblox.com"
ROBLOX_GROUP_API="https://groups.roblox.com"

# Email / SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@polarisone.com"
SMTP_PASS="replace-with-password"
SMTP_FROM_EMAIL="noreply@polarisone.com"
SMTP_FROM_NAME="Polaris Pilot"

# AI Provider
ABACUS_AI_API_KEY="replace-with-abacus-api-key"
ABACUS_AI_BASE_URL="https://routellm.abacus.ai/v1"
ABACUS_AI_MODEL="gemini-3-flash-preview"

# Encryption
ENCRYPTION_KEY="replace-with-32-char-encryption-key"

# Frontend
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE="/api"

